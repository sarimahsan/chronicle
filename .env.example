# =========================================================================
# Chronicle Environment Configuration
# Copy this file to a new file named `.env` in the same directory.
# =========================================================================

# Groq LLM API Key (Get yours at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Neo4j Database Connection Credentials
# These will be used to initialize the Neo4j Docker container and configure the backend.
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_password_here
